# spiceMap 프론트엔드 프로덕션 환경 변수 템플릿
#
# Vercel/Netlify 대시보드의 환경 변수 화면에 동일 키로 등록한다.
# 본 파일은 .env.production 으로 복사 후 값 입력. .env.production 자체는
# .gitignore 의 .env.* 패턴으로 추적 제외 (.env.example/.env.production.example 만 추적).

# V-World 지도 API 키 (필수)
# https://www.vworld.kr 에서 발급. 도메인 등록 필요 (배포 도메인 추가).
VITE_VWORLD_API_KEY=

# 백엔드 API 베이스 URL (선택)
#
# - 미설정 시: demo mode 자동 활성. mock_*.json + validation_results.json fixture 로 시연 가능.
# - 설정 시: /api/* 호출이 해당 호스트로. CORS 허용 + RLS 정책 검증 필수.
#
# 예: https://api.spicemap.example.com  (백엔드 별도 호스팅 시)
VITE_API_BASE_URL=

# 정책 카드 mock fallback 강제 (선택)
# 백엔드 연결됐지만 policy_cards 테이블이 비어 있을 때 hero shot 안전을 위해
# strategy_d13.md 결정 D 의 백업 fixture 를 강제 사용.
# 1=ON, 미설정=OFF
VITE_USE_DEMO_POLICY=
