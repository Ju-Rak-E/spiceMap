# 공공데이터포털 API 키
# https://www.data.go.kr 에서 발급
PUBLIC_DATA_API_KEY=

# 서울시 공공데이터 API 키
# https://data.seoul.go.kr 에서 발급
SEOUL_API_KEY=

# PostgreSQL 설정
# 로컬 개발: Docker Compose (docker compose up -d)
# DB_HOST=127.0.0.1
# DB_PORT=5433
# DB_NAME=spicemap
# DB_USER=postgres
# DB_PASSWORD=postgres

# 팀 공용 DB (Supabase Session Pooler) — 팀장에게 비밀번호 요청
DB_HOST=aws-1-ap-northeast-2.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.clyqvncpcfyfljbqgdig
DB_PASSWORD=

# Redis 설정
REDIS_URL=redis://localhost:6379

# 재생 모드 (시연일 DB 장애 대비)
# DEMO_MODE=1 설정 시 backend/static/demo/ 정적 스냅샷으로만 응답
# 사전에 python -m backend.pipeline.generate_demo_snapshot 실행 필요
DEMO_MODE=0
